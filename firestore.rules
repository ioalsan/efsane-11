rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function leagueDoc(leagueId) {
      return get(/databases/$(database)/documents/leagues/$(leagueId));
    }

    function isLeagueMember(leagueId) {
      return signedIn()
        && request.auth.uid in leagueDoc(leagueId).data.memberIds;
    }

    function isLeagueOwner(leagueId) {
      return signedIn()
        && leagueDoc(leagueId).data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
    }

    match /leagues/{leagueId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      allow read: if isLeagueMember(leagueId)
        || (signedIn() && resource.data.status == 'waiting');

      allow update: if signedIn()
        && (
          isLeagueOwner(leagueId)
          || request.auth.uid in resource.data.memberIds
          || request.auth.uid in request.resource.data.memberIds
        );

      allow delete: if isLeagueOwner(leagueId);

      match /teams/{teamId} {
        allow read: if isLeagueMember(leagueId);
        allow create, update: if signedIn()
          && isLeagueMember(leagueId)
          && (
            isLeagueOwner(leagueId)
            || (
              request.resource.data.ownerId == request.auth.uid
              && teamId == ('team-' + request.auth.uid)
            )
          );
        allow delete: if signedIn()
          && isLeagueMember(leagueId)
          && resource.data.ownerId == request.auth.uid;
      }

      match /fixtures/{fixtureId} {
        allow read: if isLeagueMember(leagueId);
        allow write: if isLeagueOwner(leagueId);
      }

      match /standings/{standingId} {
        allow read: if isLeagueMember(leagueId);
        allow write: if isLeagueOwner(leagueId);
      }

      match /matchReports/{reportId} {
        allow read: if isLeagueMember(leagueId);
        allow write: if isLeagueOwner(leagueId);
      }
    }
  }
}
